{
    "autoclose": true,
    "autoindent": true,
    "autoreload": true,
    "blockclose": "^[}\\])]",
    "blockinter": "^[}\\])].+?[{[(]$|:$",
    "blockopen": "[{[\\(]$",
    "comment": "//",
    "eofnewline": true,
    "fileformat": "unix",
    "findfuncregex": "^\\s*func\\s+(?:\\(.+?\\)\\s)?%word%\\(|%word%\\s*:?=\\s*func[\\s\\{\\(]",
    "indentchar": "\t",
    "keepautoindent": true,
    "matchbrace": true,
    "rmtrailingws": true,
    "smartindent": true,
    "smartpaste": true,
    "softwrap": false,
    "tabindents": false,
    "tabmovement": true,
    "tabsize": 4,
    "tabstospaces": false,
    "useformatter": true
}
